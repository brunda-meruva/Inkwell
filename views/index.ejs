<%- include('_nav') %>
<style>
  .page-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }
  .page-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
  }
  .page-header p { color: var(--ink-muted); margin-top: 0.3rem; }

  .posts-grid { display: flex; flex-direction: column; gap: 1.5rem; }

  .post-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.75rem;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .post-card:hover { box-shadow: 0 6px 28px rgba(26,18,9,0.12); transform: translateY(-1px); }

  .post-meta {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 0.85rem; flex-wrap: wrap;
  }
  .author-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--amber); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem; font-weight: 700; flex-shrink: 0;
  }
  .author-info { display: flex; flex-direction: column; }
  .author-name { font-size: 0.875rem; font-weight: 500; color: var(--ink); }
  .post-date { font-size: 0.775rem; color: var(--ink-muted); }

  .topic-pill {
    margin-left: auto;
    font-size: 0.72rem; font-weight: 500;
    background: var(--amber-light); color: var(--amber-dark);
    padding: 2px 10px; border-radius: 99px;
    text-transform: uppercase; letter-spacing: 0.05em;
  }

  .post-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 700;
    margin-bottom: 0.6rem;
    text-decoration: none; color: var(--ink);
    display: block;
    transition: color 0.15s;
  }
  .post-title:hover { color: var(--amber-dark); }

  .post-excerpt { color: var(--ink-soft); font-size: 0.93rem; margin-bottom: 1.1rem; }

  .post-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .tag {
    font-size: 0.72rem; background: var(--cream-dark);
    color: var(--ink-soft); padding: 2px 8px; border-radius: 3px;
  }

  .post-footer {
    display: flex; align-items: center; gap: 1rem;
    padding-top: 1rem; border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .like-btn {
    display: flex; align-items: center; gap: 0.4rem;
    background: none; border: 1px solid var(--border);
    border-radius: 99px; padding: 0.3rem 0.85rem;
    cursor: pointer; font-family: 'DM Sans', sans-serif;
    font-size: 0.83rem; color: var(--ink-soft);
    transition: all 0.2s;
  }
  .like-btn:hover { border-color: var(--red); color: var(--red); }
  .like-btn.liked { background: #fde8e8; border-color: var(--red); color: var(--red); }
  .like-btn .heart { font-size: 0.95rem; }

  .comment-count {
    display: flex; align-items: center; gap: 0.4rem;
    font-size: 0.83rem; color: var(--ink-muted);
    text-decoration: none;
  }
  .comment-count:hover { color: var(--ink); }

  .post-actions { margin-left: auto; display: flex; gap: 0.5rem; }

  .empty-state {
    text-align: center; padding: 4rem 2rem;
    color: var(--ink-muted);
  }
  .empty-state h2 { font-family: 'Playfair Display', serif; font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--ink); }
</style>

<div class="container">
  <div class="page-header">
    <h1>Latest Stories</h1>
    <p>Thoughts, ideas, and explorations from our community</p>
  </div>

  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <h2>No posts yet</h2>
      <p>Be the first to share something.</p>
      <% if (currentUser) { %>
        <a href="/new" class="btn btn-primary" style="margin-top:1rem">Write a Post</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="posts-grid">
      <% posts.forEach(post => { %>
        <article class="post-card">
          <div class="post-meta">
            <div class="author-avatar"><%= post.author.displayName[0].toUpperCase() %></div>
            <div class="author-info">
              <span class="author-name"><%= post.author.displayName %></span>
              <span class="post-date"><%= new Date(post.date).toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
            </div>
            <% if (post.topic) { %><span class="topic-pill"><%= post.topic %></span><% } %>
          </div>

          <a class="post-title" href="/post/<%= post.id %>"><%= post.title %></a>

          <p class="post-excerpt"><%= post.content.substring(0, 180) %><%= post.content.length > 180 ? '…' : '' %></p>

          <% if (post.tags && post.tags.length > 0) { %>
            <div class="post-tags">
              <% post.tags.forEach(tag => { %><span class="tag">#<%= tag %></span><% }) %>
            </div>
          <% } %>

          <div class="post-footer">
            <% const isLiked = likedPostIds.includes(post.id); %>
            <button
              class="like-btn <%= isLiked ? 'liked' : '' %>"
              onclick="handleLike(this, <%= post.id %>)"
              data-post-id="<%= post.id %>"
              <%= !currentUser ? 'title="Sign in to like" onclick="window.location=\'/signin\'" ' : '' %>
            >
              <span class="heart"><%= isLiked ? '❤️' : '🤍' %></span>
              <span class="like-count"><%= post.likes || 0 %></span>
            </button>

            <a class="comment-count" href="/post/<%= post.id %>#comments">
              💬 <%= post.commentCount || 0 %> comments
            </a>

            <% if (currentUser && (post.author.id === currentUser.id || currentUser.role === 'admin')) { %>
              <div class="post-actions">
                <a href="/edit/<%= post.id %>" class="btn btn-outline btn-sm">Edit</a>
                <a href="/api/posts/delete/<%= post.id %>"
                   class="btn btn-danger btn-sm"
                   onclick="return confirm('Delete this post?')">Delete</a>
              </div>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
async function handleLike(btn, postId) {
  <% if (!currentUser) { %>
    window.location = '/signin';
    return;
  <% } %>
  try {
    const res = await fetch(`/api/posts/${postId}/like`, { method: 'POST' });
    const data = await res.json();
    btn.querySelector('.like-count').textContent = data.likes;
    if (data.action === 'liked') {
      btn.classList.add('liked');
      btn.querySelector('.heart').textContent = '❤️';
    } else {
      btn.classList.remove('liked');
      btn.querySelector('.heart').textContent = '🤍';
    }
  } catch(e) { console.error(e); }
}
</script>
</body>
</html>

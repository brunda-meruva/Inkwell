<%- include('_nav') %>
<% const title = heading %>
<style>
  .form-wrap { max-width: 700px; margin: 0 auto; padding: 2.5rem 1.5rem; }

  .form-heading {
    font-family: 'Playfair Display', serif; font-size: 2rem;
    margin-bottom: 0.3rem;
  }
  .form-sub { color: var(--ink-muted); font-size: 0.9rem; margin-bottom: 2rem; }

  .form-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: 6px; padding: 2rem; box-shadow: var(--shadow);
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .form-footer { display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem; }
  .hint { font-size: 0.78rem; color: var(--ink-muted); margin-top: 0.3rem; }
</style>

<div class="form-wrap">
  <a href="/" style="display:inline-flex;align-items:center;gap:0.4rem;color:var(--ink-muted);text-decoration:none;font-size:0.875rem;margin-bottom:1.5rem">← Back</a>
  <h1 class="form-heading"><%= heading %></h1>
  <p class="form-sub"><%= post ? 'Update your post details below.' : 'Share your ideas with the world.' %></p>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="error-box"><%= error %></div>
  <% } %>

  <div class="form-card">
    <form
      action="<%= post ? '/api/posts/' + post.id : '/api/posts' %>"
      method="POST"
    >
      <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" value="<%= post ? post.title : '' %>" placeholder="A compelling title…" required />
      </div>

      <div class="form-group">
        <label for="content">Content</label>
        <textarea id="content" name="content" rows="10" placeholder="Write your post…" required><%= post ? post.content : '' %></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="tags">Tags</label>
          <input type="text" id="tags" name="tags" value="<%= post && post.tags ? post.tags.join(', ') : '' %>" placeholder="AI, Technology, Finance" />
          <p class="hint">Comma-separated — used in the knowledge graph</p>
        </div>
        <div class="form-group">
          <label for="topic">Topic</label>
          <input type="text" id="topic" name="topic" value="<%= post && post.topic ? post.topic : '' %>" placeholder="e.g. Technology" />
          <p class="hint">Broad category for clustering in the graph</p>
        </div>
      </div>

      <div class="form-footer">
        <button type="submit" class="btn btn-primary"><%= submit %></button>
        <a href="/" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>
</div>
</body>
</html>
